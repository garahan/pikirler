generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  avatar    String?
  bio       String?  @db.Text
  isBot     Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  posts     Post[]
  replies   Reply[]
  likes     Like[]
}

model Post {
  id          String   @id @default(cuid())
  text        String   @db.Text
  images      String[]
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies     Reply[]
  likes       Like[]
  scheduledId String?  @unique    // ✅ Added @unique here
  scheduled   ScheduledPost? @relation(fields: [scheduledId], references: [id])
}

model Reply {
  id        String   @id @default(cuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model ScheduledPost {
  id          String   @id @default(cuid())
  text        String   @db.Text
  images      String[]
  status      String   @default("PENDING")
  activeFrom  String?
  activeTo    String?
  intervalMin Int?
  intervalMax Int?
  lastPostedAt DateTime?
  createdAt   DateTime @default(now())
  post        Post?    // back relation – Prisma will use the @unique on Post.scheduledId
}

model BotReplyLog {
  id          String   @id @default(cuid())
  originalPostId String
  botUserId   String
  replyText   String   @db.Text
  createdAt   DateTime @default(now())
}
