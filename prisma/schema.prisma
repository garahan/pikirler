generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String?
  passwordHash String?
  avatar       String?
  bio          String?  @db.Text
  location     String?
  website      String?
  isBot        Boolean  @default(false)
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  posts        Post[]
  replies      Reply[]
  likes        Like[]
  saves        Save[]
  reposts      Repost[]
  following    Follow[] @relation("follower")
  followers    Follow[] @relation("following")
}

model Post {
  id          String   @id @default(cuid())
  text        String   @db.Text
  images      String[]
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies     Reply[]
  likes       Like[]
  saves       Save[]
  reposts     Repost[]
  scheduledId String?  @unique
  scheduled   ScheduledPost? @relation(fields: [scheduledId], references: [id])

  @@index([createdAt])
  @@index([userId])
}

model Reply {
  id        String   @id @default(cuid())
  text      String   @db.Text
  createdAt DateTime @default(now())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
}

model Save {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

model Repost {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

model ScheduledPost {
  id           String    @id @default(cuid())
  text         String    @db.Text
  images       String[]
  status       String    @default("PENDING")
  activeFrom   String?
  activeTo     String?
  intervalMin  Int?
  intervalMax  Int?
  lastPostedAt DateTime?
  createdAt    DateTime  @default(now())
  post         Post?

  @@index([status])
}

model BotReplyLog {
  id             String   @id @default(cuid())
  originalPostId String
  botUserId      String
  replyText      String   @db.Text
  createdAt      DateTime @default(now())
}
